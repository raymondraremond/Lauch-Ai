# LaunchAI Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to git.
# ─────────────────────────────────────────────────────────

# Anthropic API Key (for the AI Copilot chat feature)
# Get yours at: https://console.anthropic.com/settings/api-keys
VITE_ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Gemini API Key (Best for Free Tier!)
# Get yours at: https://aistudio.google.com/
VITE_GOOGLE_API_KEY=your_gemini_key_here

# App URL (update when you deploy)
VITE_APP_URL=http://localhost:5173

# AI Backend API Base URL
VITE_API_BASE_URL=https://launchai-server.onrender.com
